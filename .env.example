# Firebase Configuration
# Get these from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Gemini API Key
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Fallback 1)
# Get one for free at: https://console.groq.com/
VITE_GROQ_API_KEY=

# OpenRouter API Key (Fallback 2)
# Get one for free at: https://openrouter.ai/
VITE_OPENROUTER_API_KEY=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

